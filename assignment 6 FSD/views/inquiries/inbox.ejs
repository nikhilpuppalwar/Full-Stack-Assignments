<%- include('../partials/header') %>
<div class="page-banner">
  <div class="container-fluid px-4">
    <h1 class="page-banner-title"><i class="bi bi-inbox me-3"></i>Inbox</h1>
    <p class="page-banner-sub">Messages from buyers about your listings</p>
  </div>
</div>
<section class="py-5">
  <div class="container-fluid px-4">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="d-flex gap-3 mb-4">
          <a href="/inquiries/inbox" class="btn btn-accent btn-sm">Inbox (<%= inquiries.length %>)</a>
          <a href="/inquiries/sent"  class="btn btn-outline-secondary btn-sm">Sent Messages</a>
        </div>
        <% if (inquiries.length===0) { %>
        <div class="text-center py-5">
          <i class="bi bi-chat-dots" style="font-size:3rem;color:#ddd;display:block;margin-bottom:16px"></i>
          <h4>No messages yet</h4>
          <p class="text-muted">When buyers contact you, messages appear here.</p>
        </div>
        <% } else { %>
        <div class="d-flex flex-column gap-3">
          <% inquiries.forEach(inq => { %>
          <div class="inq-item">
            <div class="inq-top">
              <div class="inq-av"><%= inq.senderName ? inq.senderName[0].toUpperCase() : '?' %></div>
              <div class="inq-info">
                <span class="inq-name"><%= inq.senderName || 'Anonymous' %></span>
                <span class="inq-time"><%= new Date(inq.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></span>
              </div>
              <% if (inq.product) { %>
              <a href="/products/<%= inq.product.id %>" class="inq-prod-link">
                <img src="<%= inq.product.image %>" alt="" onerror="this.src='https://via.placeholder.com/40x36'">
                <span><%= inq.product.title.substring(0,35) %>…</span>
              </a>
              <% } %>
            </div>
            <p class="inq-msg"><%= inq.message %></p>
            <div class="inq-foot">
              <% if (inq.senderEmail) { %>
              <a href="mailto:<%= inq.senderEmail %>?subject=Re: <%= inq.product ? inq.product.title : 'Your inquiry' %>" class="btn btn-accent btn-sm">
                <i class="bi bi-reply me-1"></i>Reply via Email
              </a>
              <span class="text-muted small ms-2"><%= inq.senderEmail %></span>
              <% } %>
            </div>
          </div>
          <% }) %>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</section>
<%- include('../partials/footer') %>
