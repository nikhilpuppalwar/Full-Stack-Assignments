<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar navbar-expand-lg fixed-top" id="mainNav">
  <div class="container-fluid px-4">

    <a class="navbar-brand" href="/">
      <span class="brand-mark">B</span>AZAAR
    </a>

    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
      <i class="bi bi-list text-white fs-4"></i>
    </button>

    <div class="collapse navbar-collapse" id="navMenu">

      <form class="nav-search mx-auto" action="/products" method="GET">
        <div class="nav-search-wrap">
          <i class="bi bi-search"></i>
          <input type="text" name="search" placeholder="Search cars, phones, bikes…"
                 value="<%= typeof search !== 'undefined' ? search : '' %>">
          <button type="submit">Go</button>
        </div>
      </form>

      <ul class="navbar-nav ms-auto align-items-center gap-2">
        <li class="nav-item"><a class="nav-link" href="/products">Browse</a></li>

        <% if (currentUser) { %>
          <li class="nav-item">
            <a class="nav-link position-relative" href="/inquiries/inbox" id="inboxLink">
              <i class="bi bi-chat-dots"></i>
              <span class="inbox-badge d-none" id="inboxBadge">0</span>
            </a>
          </li>
          <li class="nav-item"><a class="nav-link" href="/wishlist"><i class="bi bi-heart"></i></a></li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle user-menu-btn" href="#" data-bs-toggle="dropdown">
              <span class="user-avatar-sm"><%= userName ? userName[0].toUpperCase() : 'U' %></span>
              <span class="d-none d-lg-inline"><%= userName %></span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end dd-dark">
              <li><a class="dropdown-item" href="/auth/profile"><i class="bi bi-person me-2"></i>Profile</a></li>
              <li><a class="dropdown-item" href="/products/my-listings"><i class="bi bi-tags me-2"></i>My Listings</a></li>
              <li><a class="dropdown-item" href="/inquiries/inbox"><i class="bi bi-inbox me-2"></i>Inbox</a></li>
              <li><a class="dropdown-item" href="/wishlist"><i class="bi bi-heart me-2"></i>Wishlist</a></li>
              <li><hr class="dropdown-divider border-secondary"></li>
              <li>
                <form action="/auth/logout" method="POST">
                  <button class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>Logout</button>
                </form>
              </li>
            </ul>
          </li>
          <li class="nav-item">
            <a href="/products/new" class="btn btn-accent btn-sm px-3">
              <i class="bi bi-plus-lg me-1"></i>Sell
            </a>
          </li>
        <% } else { %>
          <li class="nav-item"><a class="nav-link" href="/auth/login">Login</a></li>
          <li class="nav-item"><a class="btn btn-accent btn-sm px-3" href="/auth/register">Join Free</a></li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>

<!-- Flash Messages -->
<div class="flash-wrap">
  <% if (success && success.length) { %>
    <div class="alert alert-success alert-dismissible fade show flash-msg">
      <i class="bi bi-check-circle-fill me-2"></i><%= success %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
  <% if (error && error.length) { %>
    <div class="alert alert-danger alert-dismissible fade show flash-msg">
      <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
</div>
