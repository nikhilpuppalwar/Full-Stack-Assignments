<%- include('partials/header') %>

<!-- HERO -->
<section class="hero">
  <div class="hero-grid"></div>
  <div class="container-fluid px-4">
    <div class="row align-items-center" style="min-height:100vh">
      <div class="col-lg-6 py-5">
        <p class="hero-eyebrow">₹0 Listing Fee · No Commission · No Database Setup</p>
        <h1 class="hero-title">Buy &amp; Sell<br><em>Used Items</em><br>Near You.</h1>
        <p class="hero-sub">Cars, bikes, electronics, furniture and more. Post your ad in 2 minutes. Connect with buyers directly.</p>
        <div class="d-flex gap-3 flex-wrap">
          <a href="/products/new" class="btn btn-accent btn-lg">
            <i class="bi bi-plus-lg me-2"></i>Post Free Ad
          </a>
          <a href="/products" class="btn btn-outline-light btn-lg">Browse All</a>
        </div>
        <div class="hero-stats mt-5">
          <div class="hstat"><span class="hstat-n"><%= totalListings %>+</span><span class="hstat-l">Live Listings</span></div>
          <div class="hstat-div"></div>
          <div class="hstat"><span class="hstat-n">8</span><span class="hstat-l">Categories</span></div>
          <div class="hstat-div"></div>
          <div class="hstat"><span class="hstat-n">Free</span><span class="hstat-l">Always</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CATEGORY PILLS -->
<section class="cat-bar">
  <div class="container-fluid px-4">
    <div class="cat-scroll">
      <% const catIcons = {Cars:'bi-car-front-fill',Bikes:'bi-bicycle',Electronics:'bi-phone-fill',Furniture:'bi-house-fill',Clothing:'bi-bag-fill',Books:'bi-book-fill',Sports:'bi-trophy-fill',Other:'bi-grid-fill'}; %>
      <% categories.forEach(cat => { %>
      <a href="/products?category=<%= cat %>" class="cat-pill">
        <i class="bi <%= catIcons[cat] || 'bi-grid' %>"></i> <%= cat %>
      </a>
      <% }) %>
    </div>
  </div>
</section>

<!-- FEATURED -->
<% if (featured.length > 0) { %>
<section class="py-5 bg-white">
  <div class="container-fluid px-4">
    <div class="sec-hdr">
      <h2 class="sec-title"><span class="acc-bar"></span>Featured Listings</h2>
      <a href="/products" class="see-all">See All <i class="bi bi-arrow-right"></i></a>
    </div>
    <div class="row g-3 mt-1">
      <% featured.forEach(p => { %>
      <div class="col-lg-4 col-md-6"><%- include('partials/product-card', {product:p, showActions:false}) %></div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- LATEST -->
<section class="py-5">
  <div class="container-fluid px-4">
    <div class="sec-hdr">
      <h2 class="sec-title"><span class="acc-bar"></span>Latest Listings</h2>
      <a href="/products" class="see-all">Browse All <i class="bi bi-arrow-right"></i></a>
    </div>
    <% if (latest.length > 0) { %>
    <div class="row g-3 mt-1">
      <% latest.forEach(p => { %>
      <div class="col-xl-3 col-lg-4 col-md-6"><%- include('partials/product-card', {product:p, showActions:false}) %></div>
      <% }) %>
    </div>
    <% } else { %>
    <div class="text-center py-5">
      <i class="bi bi-box-seam" style="font-size:3rem;color:#ddd"></i>
      <h4 class="mt-3">No listings yet</h4>
      <a href="/products/new" class="btn btn-accent mt-3">Post First Ad</a>
    </div>
    <% } %>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="how-section py-5">
  <div class="container-fluid px-4">
    <h2 class="sec-title text-center mb-5"><span class="acc-bar mx-auto d-block mb-2"></span>How It Works</h2>
    <div class="row g-4 justify-content-center">
      <div class="col-md-4 col-lg-3 text-center">
        <div class="how-card">
          <div class="how-num">01</div>
          <i class="bi bi-camera how-ico"></i>
          <h5>Post Your Item</h5>
          <p>Upload a photo, set your price, write a description. Done in 2 minutes.</p>
        </div>
      </div>
      <div class="col-md-4 col-lg-3 text-center">
        <div class="how-card">
          <div class="how-num">02</div>
          <i class="bi bi-chat-dots how-ico"></i>
          <h5>Get Inquiries</h5>
          <p>Buyers message you directly. Negotiate and agree on a price.</p>
        </div>
      </div>
      <div class="col-md-4 col-lg-3 text-center">
        <div class="how-card">
          <div class="how-num">03</div>
          <i class="bi bi-cash-stack how-ico"></i>
          <h5>Close the Deal</h5>
          <p>Meet locally, hand over the item, collect your money. Simple.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-sec">
  <div class="container-fluid px-4 text-center">
    <h2 class="cta-title">Have Something to Sell?</h2>
    <p class="cta-sub">It takes 2 minutes. No fees. No middlemen.</p>
    <a href="<%= currentUser ? '/products/new' : '/auth/register' %>" class="btn btn-accent btn-lg mt-3">
      <i class="bi bi-plus-lg me-2"></i>Post a Free Ad
    </a>
  </div>
</section>

<%- include('partials/footer') %>
